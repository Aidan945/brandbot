{
  "name": "brandbot",
  "version": "0.1.2",
  "description": "🤖 A 3D robot mascot you brand with your own logo and colors — a drop-in React component with cursor tracking, built on Three.js.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/robot-core.d.ts",
      "default": "./dist/robot-core.js"
    },
    "./model": "./dist/nexbot-model.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "preview.png"
  ],
  "sideEffects": false,
  "homepage": "https://aidan945.github.io/brandbot/demo/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aidan945/brandbot.git"
  },
  "bugs": {
    "url": "https://github.com/Aidan945/brandbot/issues"
  },
  "author": "Aidan Zarski",
  "scripts": {
    "build": "tsc && cp src/nexbot-model.js dist/nexbot-model.js && cp src/nexbot-model.d.ts dist/nexbot-model.d.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/react": "^18.3.3",
    "@types/three": "^0.160.0"
  },
  "keywords": [
    "robot",
    "mascot",
    "3d",
    "threejs",
    "react",
    "hero",
    "brand",
    "logo",
    "cursor",
    "spline",
    "typescript"
  ],
  "license": "MIT"
}
